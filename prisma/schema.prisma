datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  phone         String?
  referralCode  String   @unique
  referredById  String?
  referredBy    User?    @relation("ReferralChain", fields: [referredById], references: [id], onDelete: SetNull)
  referredUsers User[]   @relation("ReferralChain")
  role          String   @default("user") // "admin" or "user"
  createdAt     DateTime @default(now())
}
